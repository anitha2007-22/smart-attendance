# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_ORIGIN=http://localhost:5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_attendance
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_refresh_secret_to_a_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# QR Attendance
QR_SECRET=change_this_qr_signing_secret_to_a_long_random_string
QR_TOKEN_TTL_SECONDS=20
ATTENDANCE_LATE_GRACE_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Bcrypt
BCRYPT_SALT_ROUNDS=10
